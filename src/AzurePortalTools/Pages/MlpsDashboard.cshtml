@page
@model AzurePortalTools.Pages.MlpsDashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-1">&#128736; Dashboard Operatore</h2>
<p class="text-secondary mb-4">
    Utente: <strong class="text-info">@User.Identity?.Name</strong> ·
    Tenant: <strong class="text-info">@Model.Tenant?.DisplayName</strong> ·
    Resource Group: <strong class="text-info">@Model.UserConfig?.ResourceGroup</strong>
</p>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @Model.MessageClass alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ══════ SEZIONE 1: VM ══════ -->
<div class="card bg-dark border-secondary mb-4">
    <div class="card-header border-secondary">
        <h5 class="mb-0">&#128187; Virtual Machine: <strong class="text-info">@Model.UserConfig?.VmName</strong></h5>
    </div>
    <div class="card-body">
        @if (Model.Vm != null)
        {
            var stateClass = Model.Vm.PowerState == "running" ? "text-success" :
                             Model.Vm.PowerState == "deallocated" ? "text-danger" : "text-warning";
            var stateIcon = Model.Vm.PowerState == "running" ? "🟢" :
                            Model.Vm.PowerState == "deallocated" ? "🔴" : "🟡";
            var isRunning = Model.Vm.PowerState == "running";
            var isStopped = Model.Vm.PowerState == "deallocated";

            <div class="d-flex align-items-center gap-4">
                <div>
                    <span class="fs-4 @stateClass">@stateIcon <strong>@Model.Vm.PowerState</strong></span>
                    <div class="text-secondary small mt-1">Location: @Model.Vm.Location</div>
                </div>
                <div class="d-flex gap-2 ms-auto">
                    <form method="post" asp-page-handler="StartVm" class="d-inline">
                        @Html.AntiForgeryToken()
                        @if (isRunning)
                        {
                            <button type="submit" class="btn btn-success btn-lg" disabled
                                    onclick="return confirm('Avviare la VM?')">
                                ▶ Avvia VM
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-success btn-lg"
                                    onclick="return confirm('Avviare la VM?')">
                                ▶ Avvia VM
                            </button>
                        }
                    </form>
                    <form method="post" asp-page-handler="StopVm" class="d-inline">
                        @Html.AntiForgeryToken()
                        @if (isStopped)
                        {
                            <button type="submit" class="btn btn-danger btn-lg" disabled
                                    onclick="return confirm('Fermare e deallocare la VM?')">
                                ■ Ferma VM
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-danger btn-lg"
                                    onclick="return confirm('Fermare e deallocare la VM?')">
                                ■ Ferma VM
                            </button>
                        }
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning mb-0">VM <strong>@Model.UserConfig?.VmName</strong> non trovata.</div>
        }
    </div>
</div>

<!-- ══════ SEZIONE 2: NSG Quick Apply ══════ -->
<div class="card bg-dark border-warning mb-4">
    <div class="card-header border-warning">
        <h5 class="mb-0 text-warning">&#9889; NSG Quick Apply — <strong class="text-info">@Model.UserConfig?.NsgName</strong></h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="ApplyRules">
            @Html.AntiForgeryToken()

            <!-- IP -->
            <div class="row g-3 mb-3">
                <div class="col-md-5">
                    <label class="form-label text-secondary">
                        <strong>1.</strong> IP Sorgente
                    </label>
                    <input type="text" name="SourceIp" class="form-control bg-dark text-light border-secondary"
                           placeholder="es. 1.2.3.4" required />
                </div>
            </div>

            <!-- Checkboxes servizi -->
            <div class="mb-3">
                <label class="form-label text-secondary">
                    <strong>2.</strong> Seleziona i servizi da abilitare
                </label>
                <div class="row g-3">
                    @foreach (var ps in Model.PresetStatuses)
                    {
                        var badgeClass = ps.IpAlreadyPresent ? "bg-success" :
                                         ps.Exists ? "bg-info" : "bg-secondary";
                        var badgeText = ps.IpAlreadyPresent ? "✅ IP già presente" :
                                        ps.Exists ? "⚠️ Regola esiste, IP da aggiungere" : "🆕 Regola da creare";

                        <div class="col-md-4">
                            <div class="card bg-dark border-secondary h-100">
                                <div class="card-body p-3">
                                    <div class="form-check form-switch mb-2">
                                        @if (ps.IpAlreadyPresent)
                                        {
                                            <input class="form-check-input" type="checkbox" name="Protocols"
                                                   value="@ps.Preset.Key" id="chk-@ps.Preset.Key" disabled />
                                        }
                                        else
                                        {
                                            <input class="form-check-input" type="checkbox" name="Protocols"
                                                   value="@ps.Preset.Key" id="chk-@ps.Preset.Key" checked />
                                        }
                                        <label class="form-check-label text-light" for="chk-@ps.Preset.Key">
                                            @ps.Preset.Icon <strong>@ps.Preset.DisplayName</strong>
                                        </label>
                                    </div>
                                    <div class="small">
                                        <span class="badge @badgeClass">@badgeText</span>
                                    </div>
                                    <div class="text-secondary small mt-1">
                                        Regola: <code>@ps.Preset.RuleName</code><br />
                                        Porta: <code>@ps.Preset.Port</code> · Priorità: <code>@ps.Preset.Priority</code>
                                    </div>
                                    @if (ps.CurrentIps.Any())
                                    {
                                        <div class="text-secondary small mt-1">
                                            IP attuali: @string.Join(", ", ps.CurrentIps)
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-warning btn-lg">
                &#128640; Applica Regole Selezionate
            </button>
        </form>
    </div>
</div>

<!-- ══════ SEZIONE 3: Regole NSG esistenti ══════ -->
<h5 class="text-light mb-3">Regole esistenti in <strong class="text-info">@Model.UserConfig?.NsgName</strong></h5>
@if (Model.NsgRules.Any())
{
    <div class="table-responsive">
        <table class="table table-dark table-sm table-hover align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Nome</th>
                    <th>Priorità</th>
                    <th>Direzione</th>
                    <th>Accesso</th>
                    <th>Protocollo</th>
                    <th>Porta Dest.</th>
                    <th>IP Sorgenti</th>
                    <th>Descrizione</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in Model.NsgRules)
                {
                    var accessClass = rule.Access == "Allow" ? "text-success" : "text-danger";
                    <tr>
                        <td><strong>@rule.Name</strong></td>
                        <td>@rule.Priority</td>
                        <td>@rule.Direction</td>
                        <td class="@accessClass"><strong>@rule.Access</strong></td>
                        <td>@rule.Protocol</td>
                        <td>@rule.DestinationPortRange</td>
                        <td class="small text-secondary" style="max-width:200px;word-break:break-all;">@rule.SourceAddressPrefixes</td>
                        <td class="small text-secondary">@rule.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">Nessuna regola trovata.</div>
}
