@page
@model AzurePortalTools.Pages.MlpsDashboardModel
@{
    ViewData["Title"] = "Dashboard";
    var vmConfigs = Model.UserConfig?.GetVmConfigs() ?? new();
}

<!-- Toast -->
@if (TempData["ToastMessage"] != null)
{
    <div id="liveToast" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999">
        <div class="toast show align-items-center text-white @TempData["ToastClass"] border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6">@TempData["ToastMessage"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
    <script>
        setTimeout(function () {
            var el = document.getElementById('liveToast');
            if (el) el.style.display = 'none';
        }, 4000);
    </script>
}

<h2 class="mb-1">&#128736; Dashboard Operatore</h2>
<p class="text-secondary mb-4">
    Utente: <strong class="text-info">@User.Identity?.Name</strong> ·
    Tenant: <strong class="text-info">@Model.Tenant?.DisplayName</strong> ·
    Resource Group: <strong class="text-info">@Model.UserConfig?.ResourceGroup</strong>
</p>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @Model.MessageClass alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@foreach (var vmCfg in vmConfigs)
{
    var vm = Model.VmStates.TryGetValue(vmCfg.VmName, out var v) ? v : null;
    var allowedPresets = AzurePortalTools.Models.NsgRulePreset.All
        .Where(p => vmCfg.AllowedProtocols.Contains(p.Key))
        .ToList();

    <!-- ══════ SEZIONE VM ══════ -->
    <div class="card bg-dark border-secondary mb-4">
        <div class="card-header border-secondary">
            <h5 class="mb-0">&#128187; Virtual Machine: <strong class="text-info">@vmCfg.VmName</strong></h5>
        </div>
        <div class="card-body">
            @if (vm != null)
            {
                var stateClass = vm.PowerState == "running" ? "text-success" :
                                 vm.PowerState == "deallocated" ? "text-danger" : "text-warning";
                var stateIcon = vm.PowerState == "running" ? "🟢" :
                                vm.PowerState == "deallocated" ? "🔴" : "🟡";
                var isRunning = vm.PowerState == "running";
                var isStopped = vm.PowerState == "deallocated";

                <div class="d-flex align-items-center gap-4">
                    <div>
                        <span class="fs-4 @stateClass">@stateIcon <strong>@vm.PowerState</strong></span>
                        <div class="text-secondary small mt-1">Location: @vm.Location</div>
                    </div>
                    <div class="d-flex gap-2 ms-auto">
                        <form method="post" asp-page-handler="StartVm" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="TargetVmName" value="@vmCfg.VmName" />
                            <button type="submit" class="btn btn-success btn-lg" @(isRunning ? "disabled" : "")
                                    onclick="return confirm('Avviare @vmCfg.VmName?')">
                                ▶ Avvia VM
                            </button>
                        </form>
                        <form method="post" asp-page-handler="StopVm" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="TargetVmName" value="@vmCfg.VmName" />
                            <button type="submit" class="btn btn-danger btn-lg" @(isStopped ? "disabled" : "")
                                    onclick="return confirm('Fermare e deallocare @vmCfg.VmName?')">
                                ■ Ferma VM
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">VM <strong>@vmCfg.VmName</strong> non trovata.</div>
            }
        </div>
    </div>

    <!-- ══════ SEZIONE NSG ══════ -->
    <div class="card bg-dark border-warning mb-5">
        <div class="card-header border-warning">
            <h5 class="mb-0 text-warning">&#9889; NSG Quick Apply — <strong class="text-info">@vmCfg.NsgName</strong></h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="ApplyRules">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TargetVmName" value="@vmCfg.VmName" />

                <!-- IP -->
                <div class="row g-3 mb-3">
                    <div class="col-md-5">
                        <label class="form-label text-secondary"><strong>1.</strong> IP Sorgente</label>
                        <input type="text" name="SourceIp" class="form-control bg-dark text-light border-secondary"
                               placeholder="es. 1.2.3.4" required />
                    </div>
                </div>

                <!-- Checkboxes servizi -->
                <div class="mb-3">
                    <label class="form-label text-secondary"><strong>2.</strong> Seleziona i servizi da abilitare</label>
                    <div class="row g-3">
                        @foreach (var p in allowedPresets)
                        {
                            var isChecked = p.Key != "DENODO";
                            <div class="col-md-4">
                                <div class="card bg-dark border-secondary h-100">
                                    <div class="card-body p-3 d-flex align-items-center gap-3">
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" name="Protocols"
                                                   value="@p.Key" id="chk-@vmCfg.VmName-@p.Key" @(isChecked ? "checked" : "") />
                                        </div>
                                        <label class="form-check-label text-light mb-0" for="chk-@vmCfg.VmName-@p.Key">
                                            @p.Icon <strong>@p.DisplayName</strong>
                                            <div class="text-secondary small">@p.RuleName · porta @p.Port</div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <button type="submit" class="btn btn-warning btn-lg">
                    &#128640; Applica Regole Selezionate
                </button>
            </form>
        </div>
    </div>
}