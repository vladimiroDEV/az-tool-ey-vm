@page
@model AzurePortalTools.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Azure Portal Tools – Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #0d1117; }
        .login-box { max-width: 400px; margin: 10vh auto; }
        .card { background: #161b22; border: 1px solid #30363d; }
        .card-header { background: #21262d; border-bottom: 1px solid #30363d; }
        h5 { color: #58a6ff; }
        label { color: #c9d1d9; }
        .form-control { background: #0d1117; color: #c9d1d9; border-color: #30363d; }
        .form-control:focus { background: #0d1117; color: #c9d1d9; border-color: #58a6ff; box-shadow: 0 0 0 .25rem rgba(88,166,255,.25); }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="card shadow-lg">
            <div class="card-header text-center py-3">
                <h5 class="mb-0">&#9729; Azure Portal Tools</h5>
            </div>
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Utente</label>
                        <input asp-for="Username" class="form-control" autofocus />
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Accedi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
