@page
@model AzurePortalTools.Pages.NsgModel
@{
    ViewData["Title"] = "NSG Rules";
}

<h2 class="mb-1">&#128737; NSG Rules Manager</h2>
<p class="text-secondary mb-4">Tenant: <strong class="text-info">@Model.SelectedTenant?.DisplayName</strong></p>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @Model.MessageClass alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Selettori Resource Group e NSG -->
<form method="get" class="row g-2 mb-4 align-items-end">
    <input type="hidden" name="tenantId" value="@Model.TenantId" />
    <div class="col-auto">
        <label class="form-label text-secondary small">Resource Group</label>
        <select name="resourceGroup" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
            <option value="">-- Resource Group --</option>
            @foreach (var rg in Model.ResourceGroups)
            {
                @if (rg == Model.ResourceGroup)
                {
                    <option value="@rg" selected>@rg</option>
                }
                else
                {
                    <option value="@rg">@rg</option>
                }
            }
        </select>
    </div>
    @if (Model.Nsgs.Any())
    {
        <div class="col-auto">
            <label class="form-label text-secondary small">NSG</label>
            <select name="nsgName" class="form-select bg-dark text-light border-secondary" onchange="this.form.submit()">
                <option value="">-- Seleziona NSG --</option>
                @foreach (var nsg in Model.Nsgs)
                {
                    @if (nsg == Model.NsgName)
                    {
                        <option value="@nsg" selected>@nsg</option>
                    }
                    else
                    {
                        <option value="@nsg">@nsg</option>
                    }
                }
            </select>
        </div>
    }
    <div class="col-auto">
        <a href="/Index" class="btn btn-outline-secondary">&#8592; Torna ai Tenant</a>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.NsgName))
{
    <!-- Quick Apply Card -->
    <div class="card bg-dark border-warning mb-4">
        <div class="card-header border-warning d-flex align-items-center">
            <h6 class="mb-0 text-warning">&#9889; Quick Apply — Aggiungi IP alle regole NSG</h6>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="AddRule">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tenantId" value="@Model.TenantId" />
                <input type="hidden" name="resourceGroup" value="@Model.ResourceGroup" />
                <input type="hidden" name="nsgName" value="@Model.NsgName" />

                <!-- Step 1: IP -->
                <div class="row g-3 mb-3">
                    <div class="col-md-5">
                        <label class="form-label text-secondary">
                            <strong>1.</strong> IP Sorgente
                        </label>
                        <input type="text" name="SourceIp" class="form-control bg-dark text-light border-secondary"
                               placeholder="es. 1.2.3.4" required />
                    </div>
                </div>

                <!-- Step 2: Checkboxes servizi -->
                <div class="mb-3">
                    <label class="form-label text-secondary">
                        <strong>2.</strong> Seleziona i servizi da abilitare
                    </label>
                    <div class="row g-3">
                        @foreach (var ps in Model.PresetStatuses)
                        {
                            var badgeClass = ps.IpAlreadyPresent ? "bg-success" :
                                             ps.Exists ? "bg-info" : "bg-secondary";
                            var badgeText = ps.IpAlreadyPresent ? "✅ IP già presente" :
                                            ps.Exists ? "⚠️ Regola esiste, IP da aggiungere" : "🆕 Regola da creare";

                            <div class="col-md-4">
                                <div class="card bg-dark border-secondary h-100">
                                    <div class="card-body p-3">
                                        <div class="form-check form-switch mb-2">
                                            @if (ps.IpAlreadyPresent)
                                            {
                                                <input class="form-check-input" type="checkbox" name="Protocols"
                                                       value="@ps.Preset.Key" id="chk-@ps.Preset.Key" disabled />
                                            }
                                            else
                                            {
                                                <input class="form-check-input" type="checkbox" name="Protocols"
                                                       value="@ps.Preset.Key" id="chk-@ps.Preset.Key" checked />
                                            }
                                            <label class="form-check-label text-light" for="chk-@ps.Preset.Key">
                                                @ps.Preset.Icon <strong>@ps.Preset.DisplayName</strong>
                                            </label>
                                        </div>
                                        <div class="small">
                                            <span class="badge @badgeClass">@badgeText</span>
                                        </div>
                                        <div class="text-secondary small mt-1">
                                            Regola: <code>@ps.Preset.RuleName</code><br />
                                            Porta: <code>@ps.Preset.Port</code> · Priorità: <code>@ps.Preset.Priority</code>
                                        </div>
                                        @if (ps.CurrentIps.Any())
                                        {
                                            <div class="text-secondary small mt-1">
                                                IP attuali: @string.Join(", ", ps.CurrentIps)
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Step 3: Submit -->
                <button type="submit" class="btn btn-warning btn-lg">
                    &#128640; Applica Regole Selezionate
                </button>
            </form>
        </div>
    </div>

    <!-- Tabella regole esistenti -->
    <h5 class="text-light mb-3">Regole esistenti in <strong class="text-info">@Model.NsgName</strong></h5>
    @if (Model.Rules.Any())
    {
        <div class="table-responsive">
            <table class="table table-dark table-sm table-hover align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>Nome</th>
                        <th>Priorità</th>
                        <th>Direzione</th>
                        <th>Accesso</th>
                        <th>Protocollo</th>
                        <th>Porta Dest.</th>
                        <th>IP Sorgenti</th>
                        <th>Descrizione</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rule in Model.Rules)
                    {
                        var accessClass = rule.Access == "Allow" ? "text-success" : "text-danger";
                        <tr>
                            <td><strong>@rule.Name</strong></td>
                            <td>@rule.Priority</td>
                            <td>@rule.Direction</td>
                            <td class="@accessClass"><strong>@rule.Access</strong></td>
                            <td>@rule.Protocol</td>
                            <td>@rule.DestinationPortRange</td>
                            <td class="small text-secondary" style="max-width:200px;word-break:break-all;">@rule.SourceAddressPrefixes</td>
                            <td class="small text-secondary">@rule.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Nessuna regola trovata nell'NSG <strong>@Model.NsgName</strong>.</div>
    }
}
