<!DOCTYPE html>
<html lang="it" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Azure Portal Tools</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background-color: #0d1117; color: #c9d1d9; }
        .navbar { background-color: #161b22 !important; border-bottom: 1px solid #30363d; }
        .navbar-brand { color: #58a6ff !important; font-weight: 700; }
        .nav-link { color: #c9d1d9 !important; }
        .nav-link:hover { color: #58a6ff !important; }
        footer { background-color: #161b22; border-top: 1px solid #30363d !important; color: #8b949e; }
        .card { background-color: #161b22; border-color: #30363d; }
        .table-dark { --bs-table-bg: #161b22; }
        code { color: #ff7b72; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-page="/Index">&#9729; Azure Portal Tools</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Index">&#127760; Tenant</a>
                            </li>
                        }
                        else if (User.IsInRole("Operator"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/MlpsDashboard">&#128736; Dashboard</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-secondary">&#128100; @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" href="/Logout">&#128274; Logout</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <!-- Loading Overlay -->
    <div id="loading-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:9999; justify-content:center; align-items:center;">
        <div class="text-center">
            <div class="spinner-border text-info" style="width:3rem; height:3rem;" role="status">
                <span class="visually-hidden">Caricamento...</span>
            </div>
            <div class="text-light mt-3 fs-5" id="loading-text">Operazione in corso...</div>
        </div>
    </div>

    <footer class="mt-4 py-3 text-center small">
        <div class="container">
            &copy; 2026 Azure Portal Tools
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>